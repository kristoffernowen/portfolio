---
import DefaultLayout from "./DefaultLayout.astro";

interface Props {
  title: string;
  description?: string;
  summary?: string;
  date?: Date;
  tags?: string[];
  github?: string;
  live?: string;
}

const { title, description, summary, date, tags, github, live } = Astro.props as Props;
---

<DefaultLayout title={title} description={description}>
  <article class="project">
    <header class="project-header">
      <h1>{title}</h1>
      {description && <p class="description">{description}</p>}
      {summary && <p class="summary">{summary}</p>}
      <div class="meta">
        {
          date && (
            <time datetime={date.toISOString()}>
              {date.toLocaleDateString("sv-SE", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          )
        }
        {
          tags && tags.length > 0 && (
            <ul class="tags">
              {tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )
        }
        {
          (github || live) && (
            <div class="project-links">
              {github && (
                <a
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="github-link"
                >
                  GitHub →
                </a>
              )}
              {live && (
                <a
                  href={live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="live-link"
                >
                  Live Demo →
                </a>
              )}
            </div>
          )
        }
      </div>
    </header>
    <div class="content" data-project-content>
      <slot />
    </div>
  </article>
</DefaultLayout>

<script>
  const content = document.querySelector<HTMLElement>('[data-project-content]');

  if (content && !content.dataset.enhanced) {
    const children = Array.from(content.children);
    const sections: Array<{ heading: HTMLHeadingElement; nodes: Element[] }> = [];
    const introNodes: Element[] = [];
    let currentSection: { heading: HTMLHeadingElement; nodes: Element[] } | null = null;

    for (const child of children) {
      if (child.tagName === 'H2') {
        currentSection = { heading: child as HTMLHeadingElement, nodes: [] };
        sections.push(currentSection);
        continue;
      }

      if (currentSection) {
        currentSection.nodes.push(child);
      } else {
        introNodes.push(child);
      }
    }

    if (sections.length > 0) {
      content.replaceChildren(...introNodes);

      const accordionSections: HTMLElement[] = [];

      const setExpandedSection = (indexToOpen: number | null) => {
        accordionSections.forEach((section, sectionIndex) => {
          const button = section.querySelector<HTMLButtonElement>('[data-accordion-trigger]');
          const panel = section.querySelector<HTMLElement>('[data-accordion-panel]');
          const isExpanded = indexToOpen === sectionIndex;

          if (!button || !panel) {
            return;
          }

          button.setAttribute('aria-expanded', String(isExpanded));
          panel.hidden = !isExpanded;
          section.dataset.state = isExpanded ? 'open' : 'closed';
        });
      };

      sections.forEach((section, sectionIndex) => {
        const label = section.heading.textContent?.trim() ?? '';
        const accordionSection = document.createElement('section');
        const header = document.createElement('h2');
        const button = document.createElement('button');
        const panel = document.createElement('div');
        const panelId = `project-panel-${sectionIndex}`;

        accordionSection.className = 'project-section project-accordion-item';
        header.className = 'project-accordion-heading';

        button.type = 'button';
        button.className = 'project-accordion-trigger';
        button.textContent = label;
        button.setAttribute('data-accordion-trigger', '');
        button.setAttribute('aria-controls', panelId);
        button.setAttribute('aria-expanded', String(sectionIndex === 0));

        panel.id = panelId;
        panel.className = 'project-accordion-panel';
        panel.setAttribute('data-accordion-panel', '');
        panel.hidden = sectionIndex !== 0;
        panel.append(...section.nodes);

        button.addEventListener('click', () => {
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          setExpandedSection(isExpanded ? null : sectionIndex);
        });

        header.append(button);
        accordionSection.append(header, panel);
        accordionSections.push(accordionSection);
        content.append(accordionSection);
      });

      setExpandedSection(0);

      content.dataset.enhanced = 'true';
    }
  }
</script>

<style>
  .project {
    max-width: 768px;
    margin: 0 auto;
  }

  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #334155;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #f1f5f9;
  }

  .description {
    color: #94a3b8;
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .summary {
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 62ch;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
    color: #64748b;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .tag {
    background-color: #1e293b;
    color: #60a5fa;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    border: 1px solid #334155;
  }

  .github-link {
    font-weight: 500;
  }

  .project-links {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .live-link {
    font-weight: 500;
  }

  .content :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 0.75rem;
  }

  .content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: #cbd5e1;
    margin: 1.25rem 0 0.5rem;
  }

  .content :global(p) {
    line-height: 1.75;
    color: #cbd5e1;
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    color: #cbd5e1;
  }

  .content :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.7;
  }

  .content :global(code) {
    background-color: #1e293b;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.875em;
  }

  .content :global(pre) {
    background-color: #1e293b;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .project-section + .project-section {
    margin-top: 1rem;
  }

  .project-accordion-item {
    border: 1px solid #334155;
    border-radius: 12px;
    background-color: #0f172a;
    overflow: hidden;
  }

  .project-accordion-heading {
    margin: 0;
  }

  .project-accordion-trigger {
    appearance: none;
    background: transparent;
    border: 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.1rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: #f1f5f9;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .project-accordion-trigger:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: -2px;
  }

  .project-accordion-trigger::after {
    content: "+";
    color: #60a5fa;
    font-size: 1.2rem;
    line-height: 1;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .project-accordion-item[data-state='open'] .project-accordion-trigger {
    border-bottom: 1px solid #334155;
  }

  .project-accordion-item[data-state='open'] .project-accordion-trigger::after {
    content: "−";
  }

  .project-accordion-panel {
    padding: 1rem 1.1rem 0.4rem;
  }

  @media (max-width: 640px) {
    .project-accordion-trigger {
      padding: 0.9rem 1rem;
    }

    .project-accordion-panel {
      padding: 0.9rem 1rem 0.3rem;
    }
  }
</style>
