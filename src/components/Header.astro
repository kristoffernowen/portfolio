---
const navLinks = [
  { href: '/', label: 'Hem' },
  { href: '/projects', label: 'Projekt' },
  { href: '/about', label: 'Om mig' },
  { href: '/engineering-approach', label: 'Mitt arbetssätt' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="nav">
    <a href="/" class="logo">KN</a>
    <ul class="nav-links">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'active' : ''}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    background-color: #0f172a;
    border-bottom: 1px solid #1e293b;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav {
    max-width: 1024px;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #60a5fa;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .nav-links a {
    color: #94a3b8;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: #f1f5f9;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .nav-links {
      gap: 1rem;
      font-size: 0.85rem;
    }
  }
</style>
