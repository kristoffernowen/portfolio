---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p>© {year} Kristoffer Nowén</p>
    <nav class="footer-links">
      <a href="https://github.com/kristoffernowen" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/kristoffernowen" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #0f172a;
    border-top: 1px solid #1e293b;
    padding: 1.5rem 1rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    color: #64748b;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
  }

  .footer-links a {
    color: #64748b;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #94a3b8;
    text-decoration: none;
  }
</style>
