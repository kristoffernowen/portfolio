---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout
  title="Hem"
  description="Kristoffer Nowén – systemutvecklare med fokus på .NET och moderna webblösningar."
>
  <section class="hero">
    <h1>Hej, jag är <span class="accent">Kristoffer Nowén</span></h1>
    <p class="tagline">
      Systemutvecklare med fokus på .NET, API-design och robusta
      backend-lösningar.
    </p>
    <div class="cta-links">
      <a href={`${import.meta.env.BASE_URL}projects/`} class="btn btn-primary"
        >Se mina projekt</a
      >
      <a href={`${import.meta.env.BASE_URL}about/`} class="btn btn-secondary"
        >Om mig</a
      >
    </div>
  </section>
</DefaultLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 4rem 0 3rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1.2;
  }

  .accent {
    color: #60a5fa;
  }

  .tagline {
    font-size: 1.15rem;
    color: #94a3b8;
    max-width: 520px;
    line-height: 1.7;
  }

  .cta-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.95rem;
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .btn-primary {
    background-color: #2563eb;
    color: #fff;
  }

  .btn-secondary {
    background-color: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
  }
</style>
